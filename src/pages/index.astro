---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import AppShowcase from '../components/AppShowcase.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { apps } from '../data/apps';
import { photos } from '../data/photos';

const title = 'Liang Dongjing — Indie iOS Developer & Photographer';
const description = 'Liang Dongjing is an indie iOS developer and photographer based in China. Creator of Contura, JustPad, BuzzCam, MemoryLens, SaltTrack, and BallDecide.';

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Liang Dongjing',
  alternateName: 'ldjing',
  url: 'https://ldjing.com',
  image: 'https://ldjing.com/images/avatar/portrait.jpg',
  jobTitle: 'Indie iOS Developer',
  description: 'Indie iOS developer and photographer based in China.',
  sameAs: [
    'https://x.com/ldjing',
    'https://github.com/ldjing',
  ],
  knowsAbout: ['iOS Development', 'Swift', 'Photography', 'App Development'],
  worksFor: {
    '@type': 'Organization',
    name: 'Independent',
  },
});
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <main>
    <Hero />
    <About />
    <AppShowcase apps={apps} />
    <PhotoGrid photos={photos} />
    <SocialLinks />
  </main>
</BaseLayout>

<style>
  main {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    padding-bottom: var(--space-xl);
  }
</style>
