---
interface Props {
  title: string;
  description: string;
  jsonLd?: string;
}

const { title, description, jsonLd } = Astro.props;
const siteUrl = 'https://ldjing.com';
const profileImage = `${siteUrl}/images/avatar/liangdongjingavatar.jpg`;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Liang Dongjing" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={siteUrl} />
    <link rel="image_src" href={profileImage} />
    <meta name="thumbnail" content={profileImage} />
    <meta itemprop="image" content={profileImage} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={profileImage} />
    <meta property="og:image:secure_url" content={profileImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1122" />
    <meta property="og:image:height" content="1402" />
    <meta property="og:image:alt" content="Portrait of Liang Dongjing" />
    <meta property="profile:first_name" content="Dongjing" />
    <meta property="profile:last_name" content="Liang" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@ldjing" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={profileImage} />
    <meta name="twitter:image:alt" content="Portrait of Liang Dongjing" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
  </head>
  <body>
    <header class="site-header">
      <a class="site-mark" href="/" aria-label="Liang Dongjing home">
        <img class="site-signature" src="/images/avatar/signiture.png" alt="Liang Dongjing" width="1000" height="138" />
      </a>
      <nav class="site-nav" aria-label="Primary">
        <a href="#about">About</a>
        <a href="#apps">Apps</a>
        <a href="#photography">Photos</a>
        <a href="#social">Contact</a>
      </nav>
    </header>
    <div class="container">
      <slot />
    </div>
    <footer class="site-footer">
      <p>&copy; {year} Liang Dongjing &middot; Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a></p>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    margin: 0;
    padding: 1rem max(1rem, calc((100% - var(--max-width)) / 2));
    background: rgba(247, 244, 238, 0.64);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(222, 213, 200, 0.34);
  }

  .site-mark {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-text);
  }

  .site-mark:hover {
    color: var(--color-text);
  }

  .site-mark .site-signature {
    display: block;
    width: clamp(8.5rem, 11vw, 10.5rem);
    max-width: 42vw;
    height: auto;
    object-fit: contain;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem;
    background: rgba(255, 253, 248, 0.72);
    border: 1px solid rgba(222, 213, 200, 0.82);
    border-radius: 999px;
    box-shadow: 0 10px 34px rgba(37, 33, 29, 0.06);
  }

  .site-nav a {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0 0.85rem;
    border-radius: 999px;
    color: var(--color-text-muted);
    font-size: 0.86rem;
    font-weight: 600;
  }

  .site-nav a:hover {
    background: var(--color-bg-alt);
    color: var(--color-text);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .site-footer {
    width: min(calc(100% - 2rem), var(--max-width));
    margin: 0 auto;
    padding: var(--space-xl) 0 var(--space-lg);
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .site-footer a {
    color: var(--color-text-muted);
  }

  .site-footer a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 700px) {
    .site-header {
      position: sticky;
      align-items: flex-start;
      flex-direction: column;
      gap: var(--space-sm);
      padding: var(--space-md);
    }

    .site-nav {
      width: 100%;
      justify-content: space-between;
      overflow-x: auto;
    }

    .site-mark .site-signature {
      width: clamp(8rem, 34vw, 9.5rem);
      max-width: 62vw;
    }

    .site-nav a {
      padding: 0 0.65rem;
      white-space: nowrap;
    }

    .container {
      padding: 0 var(--space-md);
    }
  }
</style>
