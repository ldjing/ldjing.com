---
---

<header class="hero">
  <div class="hero-kicker">
    <span>Independent maker</span>
    <span>iOS apps</span>
    <span>Photography</span>
  </div>

  <div class="hero-copy">
    <h1 class="hero-name">Liang Dongjing</h1>
    <p class="hero-tagline">
      I build quiet, practical iOS tools and take photographs that notice the soft edges of everyday life.
    </p>
  </div>

  <div class="hero-media" aria-label="Portrait and profile notes">
    <img
      class="hero-photo"
      src="/images/avatar/liangdongjingavatar.jpg"
      alt="Liang Dongjing — indie iOS developer and photographer"
      width="1122"
      height="1402"
    />
    <div class="hero-note">
      <p class="hero-note-label">Currently shaping</p>
      <p>Focused single-purpose apps, private on-device workflows, and a more intentional camera roll.</p>
    </div>
  </div>
</header>

<style>
  .hero {
    display: grid;
    gap: clamp(1.75rem, 4vw, 3rem);
    padding-top: clamp(2rem, 6vw, 5rem);
    animation: fadeIn 0.6s ease-out;
  }

  .hero-kicker {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    color: var(--color-text-muted);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-kicker span {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .hero-kicker span:not(:last-child)::after {
    content: "";
    width: 0.32rem;
    height: 0.32rem;
    background: var(--color-accent);
    border-radius: 50%;
  }

  .hero-copy {
    max-width: 860px;
  }

  .hero-name {
    font-family: var(--font-serif);
    font-size: clamp(4rem, 13vw, 10.5rem);
    font-weight: 500;
    letter-spacing: 0;
    color: var(--color-text);
    line-height: 0.9;
  }

  .hero-tagline {
    max-width: 720px;
    margin-top: clamp(1rem, 3vw, 1.5rem);
    font-size: clamp(1.15rem, 2.5vw, 1.9rem);
    color: var(--color-text-muted);
    line-height: 1.35;
  }

  .hero-media {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 330px);
    gap: var(--space-lg);
    align-items: end;
  }

  .hero-photo {
    width: 100%;
    height: clamp(360px, 55vw, 620px);
    object-fit: cover;
    object-position: center 18%;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
  }

  .hero-note {
    padding: var(--space-lg);
    background: var(--color-ink);
    border-radius: var(--radius);
    color: #f8f1e7;
  }

  .hero-note-label {
    margin-bottom: var(--space-sm);
    color: #d7a17e;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-note p:last-child {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    line-height: 1.35;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 820px) {
    .hero-media {
      grid-template-columns: 1fr;
    }

    .hero-note {
      padding: var(--space-md);
    }
  }

  @media (max-width: 560px) {
    .hero-kicker {
      gap: 0.45rem;
      font-size: 0.72rem;
    }

    .hero-name {
      font-size: clamp(3.6rem, 21vw, 5.5rem);
    }

    .hero-photo {
      height: 420px;
    }
  }

  @media (min-width: 960px) {
    .hero {
      grid-template-columns: minmax(0, 0.96fr) minmax(360px, 0.72fr);
      grid-template-areas:
        "kicker media"
        "copy media";
      column-gap: clamp(3rem, 7vw, 7rem);
      row-gap: var(--space-lg);
      align-items: center;
      align-content: center;
      min-height: calc(100svh - 6.25rem);
      padding-top: clamp(1rem, 3vh, 2.5rem);
    }

    .hero-kicker {
      grid-area: kicker;
      align-self: end;
    }

    .hero-copy {
      grid-area: copy;
      align-self: start;
    }

    .hero-name {
      font-size: clamp(6rem, 8vw, 8.4rem);
    }

    .hero-tagline {
      max-width: 620px;
      font-size: clamp(1.4rem, 1.65vw, 1.9rem);
    }

    .hero-media {
      grid-area: media;
      grid-template-columns: 1fr;
      gap: var(--space-md);
      align-self: center;
    }

    .hero-photo {
      height: min(66svh, 640px);
      min-height: 460px;
      object-position: center 18%;
    }

    .hero-note {
      padding: var(--space-md);
    }

    .hero-note p:last-child {
      font-size: 1.15rem;
    }
  }
</style>
