---
---

<section class="hero">
  <img class="hero-photo" src="/images/avatar/portrait.jpg" alt="Liang Dongjing" />
  <div class="hero-text">
    <h1 class="hero-name">Liang Dongjing</h1>
    <p class="hero-tagline">Developer / Photographer / Creator</p>
  </div>
</section>

<style>
  .hero {
    padding-top: var(--space-xl);
    animation: fadeIn 0.6s ease-out;
  }

  .hero-photo {
    width: 100%;
    max-height: 560px;
    object-fit: cover;
    object-position: center 20%;
    border-radius: var(--radius);
  }

  .hero-text {
    padding: var(--space-lg) 0 0;
    text-align: center;
  }

  .hero-name {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1.2;
  }

  .hero-tagline {
    margin-top: var(--space-sm);
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--color-text-muted);
    font-weight: 400;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
