---
---

<section class="hero">
  <img class="hero-avatar" src="/images/avatar/portrait.jpg" alt="Liang Dongjing" width="120" height="120" />
  <h1 class="hero-name">Liang Dongjing</h1>
  <p class="hero-tagline">Developer / Photographer / Creator</p>
</section>

<style>
  .hero {
    padding: var(--space-2xl) 0 var(--space-xl);
    text-align: center;
    animation: fadeIn 0.6s ease-out;
  }

  .hero-avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: var(--space-lg);
  }

  .hero-name {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1.2;
  }

  .hero-tagline {
    margin-top: var(--space-sm);
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--color-text-muted);
    font-weight: 400;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
