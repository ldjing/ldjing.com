---
import type { Photo } from '../data/photos';

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;
---

<section class="photo-section" id="photography" aria-labelledby="photography-heading">
  <div class="section-heading">
    <p class="section-kicker">Photography</p>
    <h2 class="section-title" id="photography-heading">Light, texture, and places that slow the day down.</h2>
  </div>
  <div class="photo-grid">
    {photos.map((photo, index) => (
      <figure class:list={['photo-item', index === 0 && 'photo-item-featured']}>
        <img src={photo.src} alt={photo.alt} loading="lazy" />
      </figure>
    ))}
  </div>
</section>

<style>
  .photo-section {
    display: grid;
    gap: var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .section-heading {
    display: grid;
    grid-template-columns: minmax(180px, 0.42fr) minmax(0, 0.58fr);
    gap: var(--space-lg);
    align-items: end;
  }

  .section-kicker {
    color: var(--color-accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-title {
    max-width: 680px;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3.8rem);
    font-weight: 500;
    line-height: 1.04;
    color: var(--color-text);
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    grid-auto-flow: dense;
    gap: 0.75rem;
  }

  .photo-item {
    margin: 0;
    min-height: 0;
    overflow: hidden;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    aspect-ratio: 1 / 1;
  }

  .photo-item-featured {
    grid-column: span 2;
    grid-row: span 2;
  }

  .photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition:
      filter var(--transition),
      transform var(--transition);
  }

  .photo-item:hover img {
    filter: saturate(1.08);
    transform: scale(1.025);
  }

  @media (max-width: 860px) {
    .photo-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .section-heading {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .photo-grid {
      grid-template-columns: 1fr;
    }

    .photo-item-featured {
      grid-column: auto;
      grid-row: auto;
    }
  }
</style>
