<section class="about" id="about" aria-labelledby="about-heading">
  <div class="section-heading">
    <p class="section-kicker">About</p>
    <h2 class="section-title" id="about-heading">Small tools, careful pictures, fewer distractions.</h2>
  </div>
  <div class="about-content">
    <div class="about-lede">
      <p>
        I'm <strong>Liang Dongjing</strong>, an indie iOS developer and photographer based in China.
        I build focused, well-crafted apps that do one thing well, then get out of the way.
      </p>
    </div>
    <div class="about-details">
      <p>
        My apps range from <a href="https://getcontura.com">Contura</a>, a 3D body tracker, to
        <a href="https://apps.apple.com/us/app/buzzcam-proraw-burst-camera/id6758300007">BuzzCam</a>,
        a ProRAW burst camera for solo shooters.
      </p>
      <p>
        Behind the lens, I'm drawn to golden-hour light, urban architecture, and landscapes at dawn.
        Photography, for me, is about learning to see.
      </p>
    </div>
  </div>
</section>

<style>
  .about {
    display: grid;
    grid-template-columns: minmax(220px, 0.82fr) minmax(0, 1.18fr);
    gap: clamp(2rem, 6vw, 5rem);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .section-kicker {
    margin-bottom: var(--space-sm);
    color: var(--color-accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-title {
    max-width: 480px;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3.8rem);
    font-weight: 500;
    line-height: 1.04;
    color: var(--color-text);
  }

  .about-content {
    display: grid;
    gap: var(--space-lg);
  }

  .about-lede {
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .about-content p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .about-lede p {
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 2.2vw, 2rem);
    line-height: 1.38;
  }

  .about-details {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-lg);
  }

  .about-content strong {
    font-weight: 600;
  }

  @media (max-width: 820px) {
    .about {
      grid-template-columns: 1fr;
    }

    .about-details {
      grid-template-columns: 1fr;
    }
  }
</style>
